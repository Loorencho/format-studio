# FTP для автодеплоя React-сайта на Beget
# Скопируйте в .env.deploy и заполните.
# .env.deploy не попадает в git.

# Сервер Beget (обычно xristou7.beget.tech)
BEGET_FTP_HOST=xristou7.beget.tech

# Создайте отдельный FTP-аккаунт в Beget:
# FTP-аккаунты → Добавить → привязать к xristou7.beget.tech/public_html
BEGET_FTP_USER=xristou7_beget
BEGET_FTP_PASSWORD=6rfFs0Hrt#sy@28

# Путь на сервере (корень public_html React-сайта)
BEGET_FTP_REMOTE_PATH=/

# 1 — подробный лог FTP (для отладки)
# BEGET_FTP_VERBOSE=1
